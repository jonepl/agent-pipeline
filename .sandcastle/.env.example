# Copy this file to .sandcastle/.env and fill in the values.
# Sandcastle loads .sandcastle/.env automatically before starting each sandbox.

# Required for Claude Code agent execution inside the sandbox.
CLAUDE_CODE_OAUTH_TOKEN=

# Required for gh CLI to recognize github.com as the remote host.
# Without this, gh commands fail with "unknown host" or "no hostname" errors.
# Always set to github.com unless you are on GitHub Enterprise (unsupported).
GH_HOST=github.com

# Required for gh CLI authentication. Set at least one.
GITHUB_TOKEN=
# GH_TOKEN=    # accepted as an alternative to GITHUB_TOKEN
